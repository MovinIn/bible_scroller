# --- Local development ---
DATABASE_URL=postgresql://bible_scroller:bible_scroller@localhost:5432/bible_scroller
MEDIA_BASE_URL=http://127.0.0.1:8000
PIPELINE_MOUNT_ROOT=
PIPELINE_IMAGES_ROOTS=
SEED_MANIFEST_PATH=
SEED_LIMIT=30

# --- Production VM (reference — set in ~/.env on 192.9.142.147) ---
# BSCROLLER_DATABASE_URL=postgresql://bscroller:PASS@172.18.0.1:5432/bscroller
# MEDIA_BASE_URL=https://bscroller.navedu.uk
# PIPELINE_MOUNT_ROOT=/output
# PIPELINE_IMAGES_ROOTS=/output/test/images;/output/prod;/output
# SEED_LIMIT=30

# --- Auth (Google Sign-In + JWT) ---
# Comma-separated OAuth client IDs whose ID tokens the API will accept (aud claim).
# Include the Web application client ID plus Android/iOS client IDs.
GOOGLE_CLIENT_IDS=315895045315-54809ltm3mnp79qurdl7512c55mvbveo.apps.googleusercontent.com,315895045315-5rtkbs5sve6c3jac9c8hh9m2i58gvrq7.apps.googleusercontent.com,315895045315-e90fn22s1q3dghmc6u7neqae3668lqnc.apps.googleusercontent.com
JWT_SECRET=dev-change-me-use-32-plus-chars-in-production

# --- Email (verification codes via Resend; preferred over SMTP) ---
# Create an API key at https://resend.com/api-keys and verify your sending domain.
RESEND_API_KEY=
RESEND_FROM=Bible Scroller <noreply@bscroller.navedu.uk>
# Optional SMTP fallback when RESEND_API_KEY is unset:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@bscroller.navedu.uk
# ALLOW_CONSOLE_MAILER=true

# --- Bible Brain API (Faith Comes By Hearing / DBP v4) ---
# Request a key at https://4.dbt.io/api_key/request
BIBLE_BRAIN_API_KEY=
BIBLE_BRAIN_BASE_URL=https://4.dbt.io/api
